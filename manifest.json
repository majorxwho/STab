{
  "manifest_version": 3,
  "name": "S标签页",
  "version": "3.2.3",
  "default_locale": "zh_CN",
  "description": "__MSG_app_description__",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "contextMenus",
    "search",
    "favicon"
  ],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://api.bing.com/*",
    "https://sp0.baidu.com/*",
    "https://lweziakgzdjfqghjnpiq.supabase.co/*",
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "快捷送入S导航",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "呼出S标签页收藏选择窗口"
    }
  }
}